# ════════════════════════════════════════════════════════════════
#   DMP AI Frontend — Environment Variables Template
#   Copy this to .env.local and fill in your actual keys
# ════════════════════════════════════════════════════════════════

# ── Clerk Keys (get from clerk.com → Your App → API Keys) ──────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# ── Backend API URL ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: NEXT_PUBLIC_API_URL=https://your-api.railway.app

# ── Frontend → Backend Shared Secret ──────────────────────────
NEXT_PUBLIC_FRONTEND_SECRET=dmp-frontend-secret
