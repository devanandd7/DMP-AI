# ════════════════════════════════════════════════════════════════
#   DMP AI API — Backend Environment Variables Template
#   Copy this to .env and fill in your actual keys
# ════════════════════════════════════════════════════════════════

# ── MongoDB Atlas ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dmpai?retryWrites=true&w=majority

# ── Groq API Keys (auto-rotation) ─────────────────────────────
GROQ_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Gemini API Keys ────────────────────────────────────────────
GEMINI_KEY_1=AIzaxxxxxxxxxxxxxxxxxxxx

# ── Admin Secret ───────────────────────────────────────────────
ADMIN_SECRET=your-strong-admin-password-here

# ── Frontend → Backend Shared Secret ──────────────────────────
FRONTEND_SECRET=dmp-frontend-secret

# ── Clerk JWKS (not used by backend, kept for reference) ───────
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
